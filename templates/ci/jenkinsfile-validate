pipeline {
  agent {
    docker {
      image 'golang:1.22'
    }
  }

  stages {
    stage('Install Validation Tools') {
      steps {
        sh '''
          apt-get update
          apt-get install -y curl unzip python3 python3-pip
          sh scripts/install-validation-tools.sh
        '''
      }
    }

    stage('Validate Observability Standard') {
      steps {
        sh 'go run ./cmd/obsctl validate --strict-tools'
      }
    }
  }
}
